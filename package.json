{
    "name": "weflow-assistant",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "electron/main.js",
    "description": "Local WeFlow companion for read-only chat analysis and manual reply assistance.",
    "scripts": {
        "start": "node src/server.js",
        "dev": "electron electron/main.js",
        "dev:server": "node --watch src/server.js",
        "desktop": "electron electron/main.js",
        "check": "node --check src/server.js && node --check electron/main.js",
        "dist": "electron-builder --win portable"
    },
    "build": {
        "appId": "local.weflow.assistant",
        "productName": "WeFlow助手",
        "asar": false,
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron/**/*",
            "src/**/*",
            "public/**/*",
            "scripts/**/*",
            "package.json",
            ".env.example"
        ],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "portable": {
            "artifactName": "${productName}-${version}-portable.exe"
        }
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "electron": "^41.1.1",
        "electron-builder": "^26.15.2"
    }
}
