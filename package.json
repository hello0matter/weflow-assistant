{
    "name":  "weflow-assistant",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "description":  "Local WeFlow companion for read-only chat analysis and manual reply assistance.",
    "scripts":  {
                    "start":  "node src/server.js",
                    "dev":  "electron electron/main.js",
                    "dev:server":  "node --watch src/server.js",
                    "desktop":  "electron electron/main.js",
        "check":  "node --check src/server.js && node --check electron/main.js"
                },
    "engines":  {
                    "node":  "\u003e=18"
                },
    "devDependencies":  {
                            "electron":  "^41.1.1"
                        }
}
